---
import '@fontsource-variable/montserrat';
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import JsonLd from '../components/JsonLd.astro';
import Analytics from '../components/Analytics.astro';
import AnalyticsBody from '../components/AnalyticsBody.astro';
import { WHATSAPP_NUMBER } from '../consts';

interface Props {
	title?: string;
	description?: string;
}

const { title, description } = Astro.props;

const localBusinessData = {
	"@context": "https://schema.org",
	"@type": "ProfessionalService",
	"name": "Bordados Córdoba",
	"image": "/brand/logo-grafito.svg", 
	"telephone": WHATSAPP_NUMBER,
	"address": {
		"@type": "PostalAddress",
		"streetAddress": "Cuauhtémoc 111, Trinidad de las Huertas",
		"addressLocality": "Oaxaca de Juárez",
		"addressRegion": "OAX",
		"postalCode": "68000",
		"addressCountry": "MX"
	},
	"geo": {
		"@type": "GeoCoordinates",
		"latitude": "17.0545", 
		"longitude": "-96.7196"
	},
	"url": "https://bordadoscordoba.com", 
	"openingHoursSpecification": [
		{
			"@type": "OpeningHoursSpecification",
			"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
			"opens": "11:00",
			"closes": "19:30"
		},
		{
			"@type": "OpeningHoursSpecification",
			"dayOfWeek": "Saturday",
			"opens": "11:00",
			"closes": "16:00"
		}
	],
	"priceRange": "$$"
};
---

<!doctype html>
<html lang="es-MX">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link id="favicon" rel="icon" type="image/svg+xml" href="/brand/isotipo-grafito.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<script is:inline>
			(function() {
				const storedTheme = localStorage.getItem("theme");
				const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
				
				const theme = storedTheme === "light" || storedTheme === "dark" 
					? storedTheme 
					: prefersDark ? "dark" : "light";
					
				document.documentElement.dataset.theme = theme;

				// Update favicon based on theme
				const updateFavicon = (currentTheme) => {
					const favicon = document.getElementById('favicon');
					if (favicon) {
						favicon.href = currentTheme === 'dark' 
							? '/brand/isotipo-marfil.svg' 
							: '/brand/isotipo-grafito.svg';
					}
				};

				updateFavicon(theme);

				// Global theme setter
				window.setTheme = function(newTheme) {
					let activeTheme = newTheme;
					if (newTheme === "system") {
						localStorage.removeItem("theme");
						const systemIsDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
						activeTheme = systemIsDark ? "dark" : "light";
					} else {
						localStorage.setItem("theme", newTheme);
					}
					document.documentElement.dataset.theme = activeTheme;
					updateFavicon(activeTheme);
				};

				// Listen for system changes if no manual override
				window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (e) => {
					if (!localStorage.getItem("theme")) {
						const activeTheme = e.matches ? "dark" : "light";
						document.documentElement.dataset.theme = activeTheme;
						updateFavicon(activeTheme);
					}
				});
			})();
		</script>

		<Analytics />
		<SEO {title} {description} />
		<JsonLd data={localBusinessData} />
	</head>
	<body class="bg-brand-bg text-brand-text font-sans antialiased selection:bg-brand-accent selection:text-white">
		<AnalyticsBody />
		<slot />
	</body>
</html>
