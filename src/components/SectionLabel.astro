---
interface Props {
  number: string;
  text: string;
}

const { number, text } = Astro.props;
---

<div class="flex items-center gap-4 py-8">
  <span class="text-xs font-sans font-bold text-brand-accent tracking-tight tabular-nums">
    [{number}]
  </span>
  <span class="text-xs font-sans font-medium uppercase tracking-[0.2em] text-brand-secondary">
    {text}
  </span>
  <div class="flex-grow h-px bg-brand-border"></div>
</div>
