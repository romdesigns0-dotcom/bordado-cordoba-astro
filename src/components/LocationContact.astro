---
import SectionLabel from './SectionLabel.astro';
import { WHATSAPP_NUMBER, WHATSAPP_LINK, CONTACT_SCHEDULE, CONTACT_ADDRESS } from '../consts';

const CONTACT_ADDRESS_UI = CONTACT_ADDRESS;
---

<section id="contacto" class="max-w-7xl mx-auto px-6 py-24 md:py-32 border-t border-brand-border">
  <SectionLabel number="07" text="Ubicación" />

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 md:gap-24">
    <!-- Información de Contacto -->
    <div>
      <h2 class="text-5xl md:text-7xl lg:text-8xl tracking-tight leading-[1.1] mb-12">
        Ubicación y <br />
        <span class="text-brand-accent">contacto</span> en Oaxaca
      </h2>

      <div class="space-y-12">
        <div class="group">
          <span class="text-[10px] uppercase tracking-[0.3em] font-black text-brand-accent block mb-4">WhatsApp / Teléfono</span>
          <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer" class="text-3xl md:text-5xl font-display hover:text-brand-accent transition-colors duration-300" data-track="whatsapp_click" data-cta-location="location_contact">
            {WHATSAPP_NUMBER}
          </a>
        </div>

        <!-- Bloque Horario -->
        <div>
          <span class="text-[10px] uppercase tracking-[0.3em] font-black text-brand-text block mb-4">Horario de Atención</span>
          <p class="text-xl md:text-2xl text-brand-secondary leading-relaxed">
            {CONTACT_SCHEDULE} <br />
            <span class="text-sm font-bold opacity-60">Domingo: Cerrado</span>
          </p>
        </div>

        <!-- Bloque Dirección -->
        <div>
          <span class="text-[10px] uppercase tracking-[0.3em] font-black text-brand-text block mb-4">Ubicación</span>
          <p class="text-xl md:text-2xl text-brand-secondary">
            {CONTACT_ADDRESS_UI}
          </p>
        </div>
      </div>

      <div class="mt-16">
        <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer" class="btn-primary !px-12 !py-6 text-xl md:text-2xl group" data-track="whatsapp_click" data-cta-location="location_contact">
          Cotizar por WhatsApp
          <svg xmlns="http://www.w3.org/2000/svg" class="ml-4 w-6 h-6 transition-transform group-hover:translate-x-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
        <p class="mt-6 text-brand-secondary text-sm leading-relaxed max-w-sm">
          Escríbenos para cotizar tu bordado. Podemos orientarte con tu logo, imagen o referencia.
        </p>
      </div>
    </div>

    <!-- Espacio para Mapa -->
    <div class="relative min-h-[400px] bg-brand-soft border border-brand-border flex items-center justify-center overflow-hidden">
      <!-- Decoración técnica background -->
      <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(var(--color-brand-text) 1px, transparent 1px); background-size: 24px 24px;"></div>
      
      <div class="z-10 text-center px-12">
        <div class="w-16 h-16 border border-brand-border rounded-full flex items-center justify-center mx-auto mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-border"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        </div>
        <p class="text-[10px] uppercase tracking-[0.3em] font-black text-brand-border mb-2">Mapa interactivo</p>
        <p class="text-brand-secondary text-sm">
          Estamos preparando nuestra ubicación interactiva. Por ahora, puedes consultarnos directamente por WhatsApp para indicaciones precisas.
        </p>
      </div>

      <!-- Líneas de corte técnico en esquinas -->
      <div class="absolute top-0 left-0 w-8 h-8 border-t border-l border-brand-border"></div>
      <div class="absolute top-0 right-0 w-8 h-8 border-t border-r border-brand-border"></div>
      <div class="absolute bottom-0 left-0 w-8 h-8 border-b border-l border-brand-border"></div>
      <div class="absolute bottom-0 right-0 w-8 h-8 border-b border-r border-brand-border"></div>
    </div>
  </div>
</section>
