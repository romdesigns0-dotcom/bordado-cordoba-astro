---
import { WHATSAPP_LINK } from '../consts';
// [Pendiente por confirmar] Reemplazar por foto real de bordado industrial
// Se elimina el placeholder de stock para evitar confusiones estéticas.
---

<section class="relative min-h-[85vh] flex flex-col justify-center overflow-hidden technical-grid px-6 border-b border-brand-border">
  <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-16 items-center py-20">
    
    <div class="z-10 order-2 lg:order-1">
      <h1 class="text-5xl md:text-7xl lg:text-8xl leading-[1] tracking-tight mb-8 animate-fade-in font-display font-semibold">
        Bordado <br class="hidden lg:block" />
        <span class="text-brand-accent font-bold italic text-[0.9em]">computarizado</span> <br />
        en Oaxaca
      </h1>
      
      <p class="text-xl md:text-2xl text-brand-secondary max-w-xl mb-12 leading-relaxed font-sans">
        Personalizamos logos, nombres, gorras, prendas y textiles con bordado limpio y preciso.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer" class="btn-primary group" data-track="whatsapp_click" data-cta-location="hero">
          Cotizar por WhatsApp
          <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      </div>
    </div>

    <div class="relative order-1 lg:order-2">
      <!-- Placeholder Técnico (No stock photo) -->
      <div class="aspect-[4/5] bg-brand-soft border border-brand-border flex flex-col items-center justify-center relative overflow-hidden group">
        <!-- Retícula técnica de fondo -->
        <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(var(--text) 1px, transparent 1px), linear-gradient(90deg, var(--text) 1px, transparent 1px); background-size: 40px 40px;"></div>
        
        <div class="z-10 text-center px-8">
          <div class="w-16 h-px bg-brand-accent mx-auto mb-4"></div>
          <p class="text-[10px] uppercase tracking-[0.3em] text-brand-muted font-bold mb-2">Precisión Industrial</p>
          <p class="text-2xl font-display font-bold text-brand-text opacity-40">
            Bordados Córdoba
          </p>
        </div>

        <!-- Decoración técnica (esquinas) -->
        <div class="absolute top-4 left-4 w-4 h-4 border-t border-l border-brand-accent/30"></div>
        <div class="absolute bottom-4 right-4 w-4 h-4 border-b border-r border-brand-accent/30"></div>
      </div>
      
      <!-- Detalle técnico / Badge -->
      <div class="absolute -bottom-4 -left-4 bg-brand-text text-brand-text-invert p-4 hidden md:block border-l-4 border-brand-accent shadow-xl">
        <p class="text-[10px] uppercase tracking-[0.2em] font-bold mb-1 opacity-70">Tipo de proceso</p>
        <p class="text-base font-sans font-bold uppercase tracking-tight">Bordado computarizado</p>
      </div>
    </div>
  </div>

  <!-- Líneas de estructura técnica -->
  <div class="absolute top-0 right-[25%] w-px h-full bg-brand-border/20 hidden lg:block"></div>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
